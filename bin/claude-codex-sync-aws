#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="claude-codex-sync-aws"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${APP_NAME}"
ENV_FILE="${CLAUDE_CODEX_SYNC_AWS_ENV:-${CONFIG_DIR}/env}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/${APP_NAME}"
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/${APP_NAME}.lock"

usage() {
  cat <<'USAGE'
Usage:
  claude-codex-sync-aws backup
  claude-codex-sync-aws init
  claude-codex-sync-aws snapshots
  claude-codex-sync-aws check
  claude-codex-sync-aws restore TARGET_DIR
  claude-codex-sync-aws doctor
  claude-codex-sync-aws print-paths
  claude-codex-sync-aws install-user-service
  claude-codex-sync-aws uninstall-user-service

Backs up raw Claude Code and Codex CLI session records to AWS S3 without
client-side encryption. Uploads are file-level incremental via aws s3 sync/cp.
The script never passes --delete, so local deletes are not mirrored to S3.
Enable S3 Versioning on the bucket to retain overwritten object versions.
USAGE
}

log() {
  printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" >&2
}

die() {
  log "error: $*"
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
  fi
}

ensure_config_dir() {
  install -d -m 0700 "$CONFIG_DIR" "$STATE_DIR"
}

codex_home() {
  printf '%s\n' "${CODEX_HOME:-$HOME/.codex}"
}

claude_home() {
  printf '%s\n' "${CLAUDE_HOME:-$HOME/.claude}"
}

aws_args() {
  local -a args=()
  if [[ -n "${AWS_PROFILE:-}" ]]; then
    args+=(--profile "$AWS_PROFILE")
  fi
  if [[ -n "${AWS_DEFAULT_REGION:-}" ]]; then
    args+=(--region "$AWS_DEFAULT_REGION")
  fi
  printf '%s\0' "${args[@]}"
}

aws_cmd() {
  local -a extra=()
  while IFS= read -r -d '' arg; do
    extra+=("$arg")
  done < <(aws_args)
  aws "${extra[@]}" "$@"
}

s3_prefix() {
  local prefix="${AWS_S3_PREFIX:-${APP_NAME}/raw}"
  prefix="${prefix#/}"
  prefix="${prefix%/}"
  printf '%s\n' "$prefix"
}

s3_base_uri() {
  [[ -n "${AWS_S3_BUCKET:-}" ]] || die "set AWS_S3_BUCKET in $ENV_FILE"
  printf 's3://%s/%s/%s\n' "$AWS_S3_BUCKET" "$(s3_prefix)" "$(hostname -s)"
}

load_aws_config() {
  load_env
  ensure_config_dir
  require_cmd aws
  require_cmd flock
}

sqlite_snapshot() {
  local src_dir="$1"
  local dst_dir="$2"
  require_cmd python3
  install -d -m 0700 "$dst_dir"

  python3 - "$src_dir" "$dst_dir" <<'PY'
import os
import sqlite3
import sys

src_dir, dst_dir = sys.argv[1], sys.argv[2]
names = [
    "state_5.sqlite",
    "logs_2.sqlite",
    "goals_1.sqlite",
    "memories_1.sqlite",
]

for name in names:
    src = os.path.join(src_dir, name)
    if not os.path.exists(src):
        continue
    dst = os.path.join(dst_dir, name)
    uri = f"file:{src}?mode=ro"
    try:
        with sqlite3.connect(uri, uri=True) as source:
            with sqlite3.connect(dst) as target:
                source.backup(target)
    except sqlite3.Error as exc:
        raise SystemExit(f"sqlite backup failed for {src}: {exc}") from exc
PY
}

build_staging_dir() {
  local stage
  stage="$(mktemp -d "${STATE_DIR}/stage.XXXXXX")"
  sqlite_snapshot "$(codex_home)" "${stage}/codex-sqlite"
  printf '%s\n' "$stage"
}

print_paths() {
  local ch cx
  cx="$(codex_home)"
  ch="$(claude_home)"
  cat <<EOF
Codex paths:
  ${cx}/sessions
  ${cx}/history.jsonl
  ${cx}/session_index.jsonl
  ${cx}/attachments
  ${cx}/memories
  ${cx}/shell_snapshots
  ${cx}/state_5.sqlite (snapshotted with Python sqlite backup API)
  ${cx}/logs_2.sqlite (snapshotted with Python sqlite backup API)
  ${cx}/goals_1.sqlite (snapshotted with Python sqlite backup API)
  ${cx}/memories_1.sqlite (snapshotted with Python sqlite backup API)

Claude paths:
  ${ch}/projects
  ${ch}/file-history
  ${ch}/plans
  ${ch}/commands
  ${ch}/backups

Intentionally not backed up:
  ${cx}/auth.json
  ${cx}/cache, ${cx}/tmp, ${cx}/.tmp, ${cx}/worktrees
  ${ch}/cache, ${ch}/debug, ${ch}/downloads, ${ch}/paste-cache
  ${HOME}/.claude.json (configuration; may contain sensitive MCP/provider data)
EOF
}

sync_dir() {
  local src="$1"
  local dst="$2"
  [[ -d "$src" ]] || return 0
  log "sync dir: $src -> $dst"
  aws_cmd s3 sync "$src" "$dst" \
    --no-follow-symlinks \
    --only-show-errors \
    --sse AES256
}

copy_file() {
  local src="$1"
  local dst="$2"
  [[ -f "$src" ]] || return 0
  log "copy file: $src -> $dst"
  aws_cmd s3 cp "$src" "$dst" \
    --only-show-errors \
    --sse AES256
}

write_manifest() {
  local stage="$1"
  local manifest="${stage}/manifest.json"
  python3 - "$manifest" "$(codex_home)" "$(claude_home)" "$(hostname -s)" <<'PY'
import datetime
import json
import os
import sys

manifest, codex_home, claude_home, host = sys.argv[1:5]
now = datetime.datetime.now(datetime.timezone.utc).isoformat()

def exists(path):
    return os.path.exists(os.path.expanduser(path))

payload = {
    "created_at": now,
    "host": host,
    "format": "raw-files-s3-sync-v1",
    "encryption": "none-client-side",
    "delete_behavior": "local deletes are not mirrored; aws s3 sync is run without --delete",
    "codex_home": codex_home,
    "claude_home": claude_home,
    "paths": {
        "codex_sessions": exists(os.path.join(codex_home, "sessions")),
        "codex_history": exists(os.path.join(codex_home, "history.jsonl")),
        "codex_state_sqlite": exists(os.path.join(codex_home, "state_5.sqlite")),
        "codex_logs_sqlite": exists(os.path.join(codex_home, "logs_2.sqlite")),
        "claude_projects": exists(os.path.join(claude_home, "projects")),
        "claude_file_history": exists(os.path.join(claude_home, "file-history")),
    },
}

with open(manifest, "w", encoding="utf-8") as f:
    json.dump(payload, f, indent=2, sort_keys=True)
    f.write("\n")
PY
  printf '%s\n' "$manifest"
}

init_repo() {
  load_aws_config
  [[ -n "${AWS_S3_BUCKET:-}" ]] || die "set AWS_S3_BUCKET in $ENV_FILE"
  aws_cmd s3api head-bucket --bucket "$AWS_S3_BUCKET" >/dev/null
  log "bucket is reachable: ${AWS_S3_BUCKET}"
  if aws_cmd s3api get-bucket-versioning --bucket "$AWS_S3_BUCKET" | grep -q '"Status": "Enabled"'; then
    log "bucket versioning is enabled"
  else
    log "warning: bucket versioning is not enabled; overwritten files may lose older versions"
  fi
}

backup() {
  load_aws_config

  (
    flock -n 9 || die "another ${APP_NAME} backup is already running"

    local base cx ch stage manifest
    base="$(s3_base_uri)"
    cx="$(codex_home)"
    ch="$(claude_home)"
    stage="$(build_staging_dir)"
    trap 'rm -rf "$stage"' RETURN
    manifest="$(write_manifest "$stage")"

    log "starting unencrypted file-level incremental backup to ${base}/"
    sync_dir "${cx}/sessions" "${base}/codex/sessions/"
    copy_file "${cx}/history.jsonl" "${base}/codex/history.jsonl"
    copy_file "${cx}/session_index.jsonl" "${base}/codex/session_index.jsonl"
    sync_dir "${cx}/attachments" "${base}/codex/attachments/"
    sync_dir "${cx}/memories" "${base}/codex/memories/"
    sync_dir "${cx}/shell_snapshots" "${base}/codex/shell_snapshots/"
    sync_dir "${stage}/codex-sqlite" "${base}/codex/sqlite/"

    sync_dir "${ch}/projects" "${base}/claude/projects/"
    sync_dir "${ch}/file-history" "${base}/claude/file-history/"
    sync_dir "${ch}/plans" "${base}/claude/plans/"
    sync_dir "${ch}/commands" "${base}/claude/commands/"
    sync_dir "${ch}/backups" "${base}/claude/backups/"

    copy_file "$manifest" "${base}/manifests/latest.json"
    copy_file "$manifest" "${base}/manifests/$(date -u '+%Y%m%dT%H%M%SZ').json"
    log "backup completed"
  ) 9>"$LOCK_FILE"
}

snapshots() {
  load_aws_config
  local base
  base="$(s3_base_uri)"
  aws_cmd s3 ls "${base}/manifests/"
}

check_repo() {
  load_aws_config
  local base
  base="$(s3_base_uri)"
  init_repo
  aws_cmd s3api list-objects-v2 \
    --bucket "$AWS_S3_BUCKET" \
    --prefix "$(s3_prefix)/$(hostname -s)/" \
    --max-keys 1 >/dev/null
  log "S3 prefix is reachable: ${base}/"
}

restore_repo() {
  load_aws_config
  local target="${1:-}"
  [[ -n "$target" ]] || die "restore requires TARGET_DIR"
  install -d -m 0700 "$target"
  aws_cmd s3 sync "$(s3_base_uri)/" "$target" --only-show-errors
}

doctor() {
  load_env
  echo "config: $ENV_FILE"
  echo "codex_home: $(codex_home)"
  echo "claude_home: $(claude_home)"
  if command -v aws >/dev/null 2>&1; then
    aws --version
    if aws_cmd sts get-caller-identity --output json >/dev/null 2>&1; then
      echo "aws_credentials: ok"
    else
      echo "aws_credentials: missing or invalid"
    fi
  else
    echo "aws: missing"
  fi
  echo "aws_profile: ${AWS_PROFILE:-<default>}"
  echo "aws_region: ${AWS_DEFAULT_REGION:-<default>}"
  echo "aws_s3_bucket: ${AWS_S3_BUCKET:-<not configured>}"
  if [[ -n "${AWS_S3_BUCKET:-}" ]]; then
    echo "aws_s3_prefix: $(s3_prefix)"
    echo "aws_s3_base_uri: $(s3_base_uri)/"
  fi
  echo "client_side_encryption: disabled"
  echo "delete_behavior: no --delete; local deletes are not mirrored to S3"
}

write_env_template() {
  local target="${1:-${CONFIG_DIR}/env}"
  if [[ -f "$target" ]]; then
    return 0
  fi
  install -d -m 0700 "$(dirname "$target")"
  cat >"$target" <<'EOF'
# claude-codex-sync-aws configuration.
AWS_S3_BUCKET=YOUR_BUCKET
AWS_S3_PREFIX=claude-codex-sync-aws/raw

# AWS credentials are intentionally not stored here by default.
# Prefer `aws configure`, `aws sso login`, an instance profile, or a secrets manager.
# If you do put static credentials here, chmod 600 this file.
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Optional overrides:
# CODEX_HOME=${HOME}/.codex
# CLAUDE_HOME=${HOME}/.claude
EOF
  chmod 0600 "$target"
}

install_user_service() {
  install -d -m 0755 "$HOME/.local/bin" "$HOME/.config/systemd/user"
  ensure_config_dir
  install -m 0755 "$0" "$HOME/.local/bin/${APP_NAME}"
  write_env_template "$ENV_FILE"

  cat >"$HOME/.config/systemd/user/${APP_NAME}.service" <<EOF
[Unit]
Description=Back up Claude Code and Codex CLI chat history to AWS S3
Documentation=https://github.com/yunwei37/${APP_NAME}

[Service]
Type=oneshot
EnvironmentFile=-%h/.config/${APP_NAME}/env
ExecStart=%h/.local/bin/${APP_NAME} backup
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
EOF

  cat >"$HOME/.config/systemd/user/${APP_NAME}.timer" <<EOF
[Unit]
Description=Weekly Claude/Codex chat history backup

[Timer]
OnCalendar=Sun *-*-* 03:30:00
Persistent=true
RandomizedDelaySec=2h
Unit=${APP_NAME}.service

[Install]
WantedBy=timers.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable --now "${APP_NAME}.timer"
  log "installed and enabled user timer: ${APP_NAME}.timer"
  log "edit config before the first backup: $ENV_FILE"
}

uninstall_user_service() {
  systemctl --user disable --now "${APP_NAME}.timer" >/dev/null 2>&1 || true
  rm -f "$HOME/.config/systemd/user/${APP_NAME}.timer" \
        "$HOME/.config/systemd/user/${APP_NAME}.service"
  systemctl --user daemon-reload
  log "removed user service and timer; left config and backups untouched"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    backup) shift; backup "$@" ;;
    init) shift; init_repo "$@" ;;
    snapshots) shift; snapshots "$@" ;;
    check) shift; check_repo "$@" ;;
    restore) shift; restore_repo "$@" ;;
    doctor) shift; doctor "$@" ;;
    print-paths) shift; print_paths "$@" ;;
    install-user-service) shift; install_user_service "$@" ;;
    uninstall-user-service) shift; uninstall_user_service "$@" ;;
    -h|--help|help|"") usage ;;
    *) usage >&2; exit 2 ;;
  esac
}

main "$@"
